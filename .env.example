# Environment variables for MCP Server

# MS Teams Configuration
# Required: URL for posting messages to Microsoft Teams via Incoming Webhook
# Get this from your Teams channel's connector settings
TEAMS_WEBHOOK_URL=https://your-organization.webhook.office.com/webhookb2/...

# HTTP Server Configuration (used by streamable-http-server)
# Optional: Port number for the HTTP server (default: 8787)
# Must be between 1 and 65535
PORT=8787

# Optional: Host to bind the HTTP server to (default: 127.0.0.1)
# Use "0.0.0.0" to listen on all interfaces (not recommended for production)
HOST=127.0.0.1
